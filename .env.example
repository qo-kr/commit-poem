# commit-poem 환경변수 설정 가이드
# 이 파일을 .env 로 복사한 뒤 값을 채워 넣으세요.
#
#   cp .env.example .env
#
# 주의: .env 파일은 절대 커밋하지 마세요 (gitignore에 포함되어 있습니다).

# ── GitHub ──────────────────────────────────────────────
# GitHub Personal Access Token (Fine-grained 권장)
# 만드는 법:
#   1. https://github.com/settings/tokens 접속
#   2. "Generate new token" → "Fine-grained token"
#   3. Resource owner: 원하는 org 선택 (예: qo-kr)
#   4. Repository access: 대상 리포 선택
#   5. Permissions → Contents: Read-only
#   6. Generate token → 값 복사
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# ── Slack ───────────────────────────────────────────────
# Slack Incoming Webhook URL
# 만드는 법:
#   1. https://api.slack.com/apps 접속
#   2. 앱 선택 (없으면 Create New App → From scratch)
#   3. 왼쪽 메뉴 Incoming Webhooks → Activate 켜기
#   4. "Add New Webhook to Workspace" → 채널 선택
#   5. 생성된 URL 복사
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Slack 이미지 게시 (선택) ─────────────────────────────
# 시와 함께 그림도 올리려면 봇 토큰 + 채널 ID 를 채우세요.
# 둘 다 설정되면 자동으로 이미지가 생성·게시되고, 비어 있으면 텍스트만 전송됩니다.
# 그림 생성은 codex CLI 의 내장 image_gen 툴(ChatGPT 정액제 인증)로 동작하며
# 별도 이미지 API 키가 필요 없습니다. (codex 가 설치·로그인되어 있어야 합니다.)
# 봇 토큰 만드는 법:
#   1. https://api.slack.com/apps 에서 앱 선택
#   2. OAuth & Permissions → Scopes → Bot Token Scopes 에 files:write 추가
#   3. Install/Reinstall to Workspace → "Bot User OAuth Token" (xoxb-...) 복사
#   4. 대상 채널에서 봇을 초대: /invite @your-app
# 채널 ID 찾는 법: 채널 우클릭 → "채널 세부정보 보기" 하단의 ID (예: C0123ABCD)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=C0123ABCD
#
# codex 실행 파일 경로가 cron PATH 에 없으면 지정 (예: ~/.bun/bin/codex)
# CODEX_BIN=codex

# ── LLM ─────────────────────────────────────────────────
# LLM API Key
#   - OpenAI: https://platform.openai.com/api-keys 에서 생성
#   - Anthropic: https://console.anthropic.com/settings/keys 에서 생성
LLM_API_KEY=sk-...

# LLM 백엔드 선택: "openai" 또는 "anthropic" (기본값: anthropic)
LLM_BACKEND=openai

# LLM 모델 (선택사항, 기본값: openai=gpt-4o-mini, anthropic=claude-3-5-haiku)
# LLM_MODEL=gpt-4o-mini
